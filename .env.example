# PocketHive Docker Registry Configuration
# Copy this file to .env and customize for your environment

# Docker registry prefix (include trailing slash)
# Examples:
#   DOCKER_REGISTRY=myregistry.io/
#   DOCKER_REGISTRY=localhost:5000/
#   DOCKER_REGISTRY=ghcr.io/yourorg/pockethive/
DOCKER_REGISTRY=

# Image version tag
POCKETHIVE_VERSION=latest

# UI STOMP credentials (optional)
VITE_STOMP_READONLY_USER=ph-observer
VITE_STOMP_READONLY_PASSCODE=ph-observer

# MCP server configuration
# Absolute path to the bundles directory (the external scenario bundles repo).
# If not set, defaults to scenarios/bundles inside this repo.
POCKETHIVE_BUNDLES_DIR=/path/to/your/bundles-repo/bundles

# PocketHive stack base URL for MCP tools
POCKETHIVE_BASE_URL=http://localhost:8088

# GitHub token for MCP github.* tools (repo scope)
GITHUB_TOKEN=
GITHUB_REPO=sepa79/PocketHive
