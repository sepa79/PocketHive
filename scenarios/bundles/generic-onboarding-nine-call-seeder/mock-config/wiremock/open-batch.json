{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPath": "/api/onboarding/batches/open",
    "bodyPatterns": [
      {
        "matchesJsonPath": "$.tenantId"
      },
      {
        "matchesJsonPath": "$.batchReference"
      },
      {
        "matchesJsonPath": {
          "expression": "$.mode",
          "equalTo": "DATA_SEED"
        }
      },
      {
        "matchesJsonPath": "$.expectedUsers"
      },
      {
        "matchesJsonPath": "$.seederRunId"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "body": "{\"ok\":true,\"seedStatus\":\"SEEDED\",\"callId\":\"open-batch\",\"batchId\":\"batch-{{jsonPath request.body '$.tenantId'}}\",\"orderId\":\"order-{{jsonPath request.body '$.tenantId'}}\",\"acceptedUsers\":\"{{jsonPath request.body '$.expectedUsers'}}\"}",
    "transformers": [
      "response-template"
    ]
  }
}
