{
  "request": {
    "method": "POST",
    "urlPath": "/api/six-auth/start",
    "headers": {
      "Authorization": {
        "equalTo": "Bearer six-step-token"
      },
      "x-ph-proof-run": {
        "equalTo": "http-sequence-six-auth-flow"
      }
    }
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "ok": true,
      "callId": "start"
    }
  }
}
