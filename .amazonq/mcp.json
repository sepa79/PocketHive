{
  "mcpServers": {
    "pockethive-bundles": {
      "url": "http://localhost:3100/mcp",
      "timeout": 300000,
      "disabled": false
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp"
      ],
      "disabled": true
    },
    "hivemind": {
      "command": "node",
      "args": [
        "../../HiveMind/HiveMind/hivemind-mcp/src/server.mjs"
      ],
      "env": {
        "HIVEMIND_API_BASE_URL": "http://localhost:4010"
      },
      "timeout": 60000,
      "disabled": false
    }
  }
}
