{
  "mcpServers": {
    "pockethive-bundles": {
      "command": "node",
      "args": [
        "<absolute-windows-path-to-repo>\\tools\\mcp-server\\start.cjs"
      ],
      "disabled": false
    },
    "atlassian": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp"
      ],
      "disabled": true
    },
    "hivemind": {
      "command": "node",
      "args": [
        "<absolute-path-to-hivemind-mcp>/src/server.mjs"
      ],
      "env": {
        "HIVEMIND_API_BASE_URL": "http://localhost:4010"
      },
      "disabled": false
    }
  }
}
