{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:pockethive:schema:managed-test-data-ui-acceptance-registry:v1",
  "title": "PocketHive Managed Test Data UI Acceptance Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "registryId",
    "status",
    "assessment",
    "parentRequirement",
    "sources",
    "requirements"
  ],
  "properties": {
    "$schema": {
      "const": "./managed-test-data-ui-acceptance-registry.schema.json"
    },
    "schemaVersion": {
      "const": "pockethive.managed-test-data-ui-acceptance-registry/v1"
    },
    "registryId": {
      "const": "managed-test-data-ui-acceptance"
    },
    "status": {
      "const": "DESIGN_BASELINE"
    },
    "assessment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designReviewGate",
        "designReviewStatus",
        "teamApprovalGate",
        "teamApprovalStatus",
        "implementationGate",
        "implementationEvidenceStatus",
        "releaseGate",
        "releaseQualificationStatus",
        "scopeNote"
      ],
      "properties": {
        "designReviewGate": {"const": "G-DESIGN-READY-v1"},
        "designReviewStatus": {"enum": ["PASS", "FAIL", "INCONCLUSIVE"]},
        "teamApprovalGate": {"const": "G-TEAM-APPROVED-v1"},
        "teamApprovalStatus": {"enum": ["NOT_EVALUATED", "PASS", "FAIL", "INCONCLUSIVE"]},
        "implementationGate": {"const": "G-M1-INTERNAL-v1"},
        "implementationEvidenceStatus": {"enum": ["NOT_RUN", "PASS", "FAIL", "INCONCLUSIVE"]},
        "releaseGate": {"const": "dataset-qualified-core"},
        "releaseQualificationStatus": {"enum": ["NOT_RUN", "PASS", "FAIL", "INCONCLUSIVE"]},
        "scopeNote": {"type": "string", "minLength": 1}
      }
    },
    "parentRequirement": {
      "const": "FUN-014"
    },
    "sources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lifecycleSpec", "uiSpec", "assuranceStrategy"],
      "properties": {
        "lifecycleSpec": {"type": "string", "minLength": 1},
        "uiSpec": {"type": "string", "minLength": 1},
        "assuranceStrategy": {"type": "string", "minLength": 1}
      }
    },
    "requirements": {
      "type": "array",
      "minItems": 43,
      "maxItems": 43,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/requirement"}
    }
  },
  "$defs": {
    "requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "parent",
        "sourceSection",
        "category",
        "applicability",
        "minimumConfidenceGrade",
        "primaryCharter",
        "supportingCharters",
        "risks",
        "oracleIds",
        "evidenceOwner",
        "evidenceState",
        "releaseGateIds"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^DSUI-(A11Y|API|ARCH|DATA|PERF|SEC|SEM|STATE|VIEW)-[0-9]{3}$"
        },
        "parent": {"const": "FUN-014"},
        "sourceSection": {"const": "managed-datasets-operator-ui-design-spec.md#20-acceptance-requirements"},
        "category": {
          "enum": ["A11Y", "API", "ARCH", "DATA", "PERF", "SEC", "SEM", "STATE", "VIEW"]
        },
        "applicability": {"const": "REQUIRED_CORE"},
        "minimumConfidenceGrade": {"type": "integer", "minimum": 3, "maximum": 5},
        "primaryCharter": {
          "enum": ["CH-34", "CH-35", "CH-36", "CH-37", "CH-38"]
        },
        "supportingCharters": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "enum": ["CH-34", "CH-35", "CH-36", "CH-37", "CH-38", "CH-39", "CH-40"]
          }
        },
        "risks": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "pattern": "^R-[A-Z0-9-]+$"}
        },
        "oracleIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "OR-EXT-EFFECT",
              "OR-MAPPER",
              "OR-FITNESS",
              "OR-AUTHZ",
              "OR-PG",
              "OR-RABBIT",
              "OR-TIME",
              "OR-WORKER-SINK",
              "OR-UI",
              "OR-CANARY",
              "OR-RESOURCE",
              "OR-REGISTRY"
            ]
          }
        },
        "evidenceOwner": {
          "enum": [
            "ACCESSIBILITY_QA_OWNER",
            "ARCHITECTURE_OWNER",
            "PERFORMANCE_QA_OWNER",
            "PRODUCT_UX_OWNER",
            "SECURITY_OWNER",
            "UI_DELIVERY_OWNER"
          ]
        },
        "evidenceState": {"$ref": "#/$defs/evidenceState"},
        "releaseGateIds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"const": "dataset-qualified-core"}
        }
      }
    },
    "evidenceState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "designReviewGate",
        "designReviewStatus",
        "designEvidenceRefs",
        "implementationGate",
        "implementationStatus",
        "implementationEvidenceRefs",
        "releaseGate",
        "releaseStatus",
        "releaseEvidenceRefs"
      ],
      "properties": {
        "designReviewGate": {"const": "G-DESIGN-READY-v1"},
        "designReviewStatus": {"enum": ["PASS", "FAIL", "INCONCLUSIVE"]},
        "designEvidenceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "implementationGate": {"const": "G-M1-INTERNAL-v1"},
        "implementationStatus": {"enum": ["NOT_RUN", "PASS", "FAIL", "INCONCLUSIVE"]},
        "implementationEvidenceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "releaseGate": {"const": "dataset-qualified-core"},
        "releaseStatus": {"enum": ["NOT_RUN", "PASS", "FAIL", "INCONCLUSIVE"]},
        "releaseEvidenceRefs": {
          "type": "array",
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      },
      "allOf": [
        {
          "if": {"properties": {"designReviewStatus": {"const": "PASS"}}},
          "then": {"properties": {"designEvidenceRefs": {"type": "array", "minItems": 1}}}
        },
        {
          "if": {"properties": {"implementationStatus": {"const": "PASS"}}},
          "then": {"properties": {"implementationEvidenceRefs": {"type": "array", "minItems": 1}}}
        },
        {
          "if": {"properties": {"releaseStatus": {"const": "PASS"}}},
          "then": {"properties": {"releaseEvidenceRefs": {"type": "array", "minItems": 1}}}
        }
      ]
    }
  }
}
