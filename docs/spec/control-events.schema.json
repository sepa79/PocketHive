{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pockethive.dev/docs/spec/control-events.schema.json",
  "title": "PocketHive Control-Plane Envelope v2",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ControlSignal" },
    { "$ref": "#/$defs/CommandResult" },
    { "$ref": "#/$defs/CommandOutcome" },
    { "$ref": "#/$defs/JournalEvent" },
    { "$ref": "#/$defs/StatusFullMetric" },
    { "$ref": "#/$defs/StatusDeltaMetric" },
    { "$ref": "#/$defs/AlertEvent" }
  ],
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "NullableNonEmptyString": {
      "oneOf": [
        { "$ref": "#/$defs/NonEmptyString" },
        { "type": "null" }
      ]
    },
    "Scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["swarmId", "role", "instance"],
      "properties": {
        "swarmId": { "$ref": "#/$defs/NonEmptyString" },
        "role": { "$ref": "#/$defs/NonEmptyString" },
        "instance": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "RuntimeMeta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["templateId", "runId"],
      "properties": {
        "templateId": { "$ref": "#/$defs/NonEmptyString" },
        "runId": { "$ref": "#/$defs/NonEmptyString" },
        "containerId": { "$ref": "#/$defs/NullableNonEmptyString" },
        "image": { "$ref": "#/$defs/NullableNonEmptyString" },
        "stackName": { "$ref": "#/$defs/NullableNonEmptyString" }
      }
    },
    "EnvelopeBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "version",
        "kind",
        "type",
        "origin",
        "scope",
        "correlationId",
        "idempotencyKey",
        "data"
      ],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "version": { "const": "2" },
        "kind": { "type": "string", "enum": ["signal", "result", "outcome", "journal", "event", "metric"] },
        "type": { "$ref": "#/$defs/NonEmptyString" },
        "origin": { "$ref": "#/$defs/NonEmptyString" },
        "scope": { "$ref": "#/$defs/Scope" },
        "correlationId": { "$ref": "#/$defs/NullableNonEmptyString" },
        "idempotencyKey": { "$ref": "#/$defs/NullableNonEmptyString" },
        "runtime": { "$ref": "#/$defs/RuntimeMeta" },
        "data": { "type": "object" }
      }
    },
    "EventRuntimeScopeRule": {
      "if": {
        "properties": {
          "scope": {
            "properties": { "swarmId": { "const": "ALL" } },
            "required": ["swarmId"]
          }
        },
        "required": ["scope"]
      },
      "then": { "not": { "required": ["runtime"] } },
      "else": { "required": ["runtime"] }
    },
    "SignalEnvelopeBase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "version",
        "kind",
        "type",
        "origin",
        "scope",
        "correlationId",
        "idempotencyKey",
        "data"
      ],
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "version": { "const": "2" },
        "kind": { "const": "signal" },
        "type": { "$ref": "#/$defs/SignalType" },
        "origin": { "$ref": "#/$defs/NonEmptyString" },
        "scope": { "$ref": "#/$defs/Scope" },
        "correlationId": { "$ref": "#/$defs/NonEmptyString" },
        "idempotencyKey": { "$ref": "#/$defs/NonEmptyString" },
        "data": { "type": "object" }
      }
    },
    "CommandType": {
      "type": "string",
      "enum": ["swarm-create", "swarm-start", "swarm-stop", "swarm-remove", "config-update"]
    },
    "SignalType": {
      "type": "string",
      "enum": ["swarm-start", "swarm-stop", "swarm-remove", "config-update", "status-request"]
    },
    "TerminalData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "retryable", "context"],
      "properties": {
        "status": { "$ref": "swarm-lifecycle.schema.json#/$defs/TerminalStatus" },
        "retryable": { "type": "boolean" },
        "context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "StartStopTerminalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "requestedWorkloadState", "observedWorkloadState", "nonConvergedWorkers"],
      "properties": {
        "target": { "$ref": "swarm-lifecycle.schema.json#/$defs/Target" },
        "requestedWorkloadState": { "$ref": "swarm-lifecycle.schema.json#/$defs/WorkloadIntent" },
        "observedWorkloadState": { "$ref": "swarm-lifecycle.schema.json#/$defs/WorkloadState" },
        "nonConvergedWorkers": {
          "type": "array",
          "items": { "$ref": "swarm-lifecycle.schema.json#/$defs/Target" },
          "uniqueItems": true
        }
      }
    },
    "CreateTerminalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "runtimeIntent", "controllerState", "workloadState", "startupArtifactSha256"],
      "properties": {
        "target": { "$ref": "swarm-lifecycle.schema.json#/$defs/Target" },
        "runtimeIntent": { "$ref": "swarm-lifecycle.schema.json#/$defs/RuntimeIntent" },
        "controllerState": { "$ref": "swarm-lifecycle.schema.json#/$defs/ControllerState" },
        "workloadState": { "$ref": "swarm-lifecycle.schema.json#/$defs/WorkloadState" },
        "startupArtifactSha256": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "RemoveTerminalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "removedResources", "remainingResources", "errors"],
      "properties": {
        "target": { "$ref": "swarm-lifecycle.schema.json#/$defs/Target" },
        "removedResources": {
          "type": "array",
          "items": { "$ref": "swarm-lifecycle.schema.json#/$defs/RemoveResource" },
          "uniqueItems": true
        },
        "remainingResources": {
          "type": "array",
          "items": { "$ref": "swarm-lifecycle.schema.json#/$defs/RemoveResource" },
          "uniqueItems": true
        },
        "errors": {
          "type": "array",
          "items": { "$ref": "swarm-lifecycle.schema.json#/$defs/RemoveError" }
        }
      }
    },
    "ConfigUpdateTerminalContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "requestedEnabled", "observedEnabled", "appliedConfigSha256"],
      "properties": {
        "target": { "$ref": "swarm-lifecycle.schema.json#/$defs/Target" },
        "requestedEnabled": { "type": ["boolean", "null"] },
        "observedEnabled": { "type": ["boolean", "null"] },
        "appliedConfigSha256": { "$ref": "#/$defs/NullableNonEmptyString" }
      }
    },
    "ControlSignal": {
      "allOf": [
        { "$ref": "#/$defs/SignalEnvelopeBase" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "signal" },
            "type": { "$ref": "#/$defs/SignalType" },
            "correlationId": { "$ref": "#/$defs/NonEmptyString" },
            "idempotencyKey": { "$ref": "#/$defs/NonEmptyString" },
            "data": {
              "type": "object",
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "CommandResult": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        { "$ref": "#/$defs/EventRuntimeScopeRule" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "result" },
            "type": {
              "type": "string",
              "enum": ["swarm-start", "swarm-stop", "config-update"]
            },
            "correlationId": { "$ref": "#/$defs/NonEmptyString" },
            "idempotencyKey": { "$ref": "#/$defs/NonEmptyString" },
            "data": { "$ref": "#/$defs/TerminalData" }
          }
        },
        {
          "if": {
            "properties": { "type": { "enum": ["swarm-start", "swarm-stop"] } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "data": {
                "properties": { "context": { "$ref": "#/$defs/StartStopTerminalContext" } }
              }
            }
          },
          "else": {
            "properties": {
              "data": {
                "properties": { "context": { "$ref": "#/$defs/ConfigUpdateTerminalContext" } }
              }
            }
          }
        }
      ]
    },
    "JournalEvent": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        { "$ref": "#/$defs/EventRuntimeScopeRule" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "journal" },
            "type": { "const": "work-journal" },
            "correlationId": { "$ref": "#/$defs/NonEmptyString" },
            "idempotencyKey": { "$ref": "#/$defs/NonEmptyString" },
            "data": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": true
            }
          }
        }
      ]
    },
    "CommandOutcome": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        { "$ref": "#/$defs/EventRuntimeScopeRule" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "outcome" },
            "type": { "$ref": "#/$defs/CommandType" },
            "scope": {
              "allOf": [
                { "$ref": "#/$defs/Scope" },
                {
                  "type": "object",
                  "properties": {
                    "role": { "const": "orchestrator" }
                  }
                }
              ]
            },
            "correlationId": { "$ref": "#/$defs/NonEmptyString" },
            "idempotencyKey": { "$ref": "#/$defs/NonEmptyString" },
            "data": { "$ref": "#/$defs/TerminalData" }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "swarm-create" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "data": { "properties": { "context": { "$ref": "#/$defs/CreateTerminalContext" } } }
            }
          },
          "else": {
            "if": {
              "properties": { "type": { "enum": ["swarm-start", "swarm-stop"] } },
              "required": ["type"]
            },
            "then": {
              "properties": {
                "data": { "properties": { "context": { "$ref": "#/$defs/StartStopTerminalContext" } } }
              }
            },
            "else": {
              "if": {
                "properties": { "type": { "const": "swarm-remove" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "data": { "properties": { "context": { "$ref": "#/$defs/RemoveTerminalContext" } } }
                }
              },
              "else": {
                "properties": {
                  "data": { "properties": { "context": { "$ref": "#/$defs/ConfigUpdateTerminalContext" } } }
                }
              }
            }
          }
        }
      ]
    },
    "QueueStatsEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["depth", "consumers"],
      "properties": {
        "depth": { "type": "integer", "minimum": 0 },
        "consumers": { "type": "integer", "minimum": 0 },
        "oldestAgeSec": { "type": "number", "minimum": 0 }
      }
    },
    "MetricIoQueues": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "in": { "type": "array", "items": { "type": "string" } },
        "out": { "type": "array", "items": { "type": "string" } },
        "routes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "MetricIoWork": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "queues": { "$ref": "#/$defs/MetricIoQueues" },
        "queueStats": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/QueueStatsEntry" }
        }
      }
    },
    "MetricIoControl": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "queues": { "$ref": "#/$defs/MetricIoQueues" }
      }
    },
    "MetricIo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "work": { "$ref": "#/$defs/MetricIoWork" },
        "control": { "$ref": "#/$defs/MetricIoControl" }
      }
    },
    "IoInputState": {
      "type": "string",
      "enum": ["ok", "out-of-data", "backpressure", "upstream-error", "unknown"]
    },
    "IoOutputState": {
      "type": "string",
      "enum": ["ok", "blocked", "throttled", "downstream-error", "unknown"]
    },
    "IoState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input", "output"],
      "properties": {
        "input": { "$ref": "#/$defs/IoInputState" },
        "output": { "$ref": "#/$defs/IoOutputState" },
        "context": { "type": "object", "additionalProperties": true }
      }
    },
    "MetricIoState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "work": { "$ref": "#/$defs/IoState" },
        "filesystem": { "$ref": "#/$defs/IoState" }
      }
    },
    "WorkerObservation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "instance", "enabled", "tps", "lastSeenAt", "stale", "ioState"],
      "properties": {
        "role": { "$ref": "#/$defs/NonEmptyString" },
        "instance": { "$ref": "#/$defs/NonEmptyString" },
        "enabled": { "type": "boolean" },
        "lastSeenAt": { "type": "string", "format": "date-time" },
        "stale": { "type": "boolean" },
        "tps": { "type": "integer", "minimum": 0 },
        "runtime": { "$ref": "#/$defs/RuntimeMeta" },
        "config": { "type": "object", "additionalProperties": true },
        "ioState": { "$ref": "#/$defs/MetricIoState" }
      }
    },
    "ControllerStatusFullContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controllerState",
        "workloadState",
        "health",
        "startupReady",
        "startupArtifactSha256",
        "watermarkAt",
        "expectedWorkers",
        "workers"
      ],
      "properties": {
        "controllerState": { "$ref": "swarm-lifecycle.schema.json#/$defs/ControllerState" },
        "workloadState": { "$ref": "swarm-lifecycle.schema.json#/$defs/WorkloadState" },
        "health": { "$ref": "swarm-lifecycle.schema.json#/$defs/Health" },
        "startupReady": { "type": "boolean" },
        "startupArtifactSha256": { "$ref": "#/$defs/NonEmptyString" },
        "watermarkAt": { "type": "string", "format": "date-time" },
        "expectedWorkers": {
          "type": "array",
          "items": { "$ref": "swarm-lifecycle.schema.json#/$defs/Target" },
          "uniqueItems": true
        },
        "workers": {
          "type": "array",
          "items": { "$ref": "#/$defs/WorkerObservation" }
        },
        "bindings": { "type": "object", "additionalProperties": true },
        "swarmDiagnostics": { "type": "object", "additionalProperties": true },
        "scenario": { "type": "object", "additionalProperties": true },
        "bufferGuard": { "type": "object", "additionalProperties": true },
        "location": { "$ref": "#/$defs/NonEmptyString" },
        "sutId": { "$ref": "#/$defs/NullableNonEmptyString" },
        "networkMode": { "type": "string", "enum": ["DIRECT", "PROXIED"] },
        "networkProfileId": { "$ref": "#/$defs/NullableNonEmptyString" }
      }
    },
    "ControllerStatusDeltaContext": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controllerState", "workloadState", "health", "startupReady", "watermarkAt"],
      "properties": {
        "controllerState": { "$ref": "swarm-lifecycle.schema.json#/$defs/ControllerState" },
        "workloadState": { "$ref": "swarm-lifecycle.schema.json#/$defs/WorkloadState" },
        "health": { "$ref": "swarm-lifecycle.schema.json#/$defs/Health" },
        "startupReady": { "type": "boolean" },
        "watermarkAt": { "type": "string", "format": "date-time" },
        "swarmDiagnostics": { "type": "object", "additionalProperties": true },
        "scenario": { "type": "object", "additionalProperties": true },
        "bufferGuard": { "type": "object", "additionalProperties": true },
        "location": { "$ref": "#/$defs/NonEmptyString" }
      }
    },
    "WorkerStatusFullData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "config", "startedAt", "io", "ioState"],
      "properties": {
        "enabled": { "type": "boolean" },
        "config": { "type": "object", "additionalProperties": true },
        "tps": { "type": "integer", "minimum": 0 },
        "startedAt": { "type": "string", "format": "date-time" },
        "io": { "$ref": "#/$defs/MetricIo" },
        "ioState": { "$ref": "#/$defs/MetricIoState" },
        "context": { "type": "object", "additionalProperties": true }
      }
    },
    "ControllerStatusFullData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config", "startedAt", "io", "ioState", "context"],
      "properties": {
        "config": { "type": "object", "additionalProperties": true },
        "startedAt": { "type": "string", "format": "date-time" },
        "io": { "$ref": "#/$defs/MetricIo" },
        "ioState": { "$ref": "#/$defs/MetricIoState" },
        "context": { "$ref": "#/$defs/ControllerStatusFullContext" }
      }
    },
    "WorkerStatusDeltaData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "ioState"],
      "properties": {
        "enabled": { "type": "boolean" },
        "tps": { "type": "integer", "minimum": 0 },
        "ioState": { "$ref": "#/$defs/MetricIoState" },
        "context": { "type": "object", "additionalProperties": true }
      }
    },
    "ControllerStatusDeltaData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ioState", "context"],
      "properties": {
        "ioState": { "$ref": "#/$defs/MetricIoState" },
        "context": { "$ref": "#/$defs/ControllerStatusDeltaContext" }
      }
    },
    "ManagerStatusFullData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config", "startedAt", "io", "ioState", "context"],
      "properties": {
        "config": { "type": "object", "additionalProperties": true },
        "startedAt": { "type": "string", "format": "date-time" },
        "io": { "$ref": "#/$defs/MetricIo" },
        "ioState": { "$ref": "#/$defs/MetricIoState" },
        "context": { "type": "object", "additionalProperties": true }
      }
    },
    "ManagerStatusDeltaData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context"],
      "properties": {
        "ioState": { "$ref": "#/$defs/MetricIoState" },
        "context": { "type": "object", "additionalProperties": true }
      }
    },
    "StatusFullMetric": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        { "$ref": "#/$defs/EventRuntimeScopeRule" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "metric" },
            "type": { "const": "status-full" },
            "correlationId": { "type": "null" },
            "idempotencyKey": { "type": "null" }
          }
        },
        {
          "if": {
            "properties": {
              "scope": {
                "properties": { "role": { "const": "swarm-controller" } },
                "required": ["role"]
              }
            },
            "required": ["scope"]
          },
          "then": { "properties": { "data": { "$ref": "#/$defs/ControllerStatusFullData" } } },
          "else": {
            "if": {
              "properties": {
                "scope": {
                  "properties": { "role": { "const": "orchestrator" } },
                  "required": ["role"]
                }
              },
              "required": ["scope"]
            },
            "then": { "properties": { "data": { "$ref": "#/$defs/ManagerStatusFullData" } } },
            "else": { "properties": { "data": { "$ref": "#/$defs/WorkerStatusFullData" } } }
          }
        }
      ]
    },
    "StatusDeltaMetric": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        { "$ref": "#/$defs/EventRuntimeScopeRule" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "metric" },
            "type": { "const": "status-delta" },
            "correlationId": { "type": "null" },
            "idempotencyKey": { "type": "null" }
          }
        },
        {
          "if": {
            "properties": {
              "scope": {
                "properties": { "role": { "const": "swarm-controller" } },
                "required": ["role"]
              }
            },
            "required": ["scope"]
          },
          "then": { "properties": { "data": { "$ref": "#/$defs/ControllerStatusDeltaData" } } },
          "else": {
            "if": {
              "properties": {
                "scope": {
                  "properties": { "role": { "const": "orchestrator" } },
                  "required": ["role"]
                }
              },
              "required": ["scope"]
            },
            "then": { "properties": { "data": { "$ref": "#/$defs/ManagerStatusDeltaData" } } },
            "else": { "properties": { "data": { "$ref": "#/$defs/WorkerStatusDeltaData" } } }
          }
        }
      ]
    },
    "AlertEvent": {
      "allOf": [
        { "$ref": "#/$defs/EnvelopeBase" },
        { "$ref": "#/$defs/EventRuntimeScopeRule" },
        {
          "type": "object",
          "properties": {
            "kind": { "const": "event" },
            "type": { "const": "alert" },
            "data": {
              "type": "object",
              "additionalProperties": false,
              "required": ["level", "code", "message"],
              "properties": {
                "level": { "type": "string", "enum": ["info", "warn", "error"] },
                "code": { "$ref": "#/$defs/NonEmptyString" },
                "message": { "$ref": "#/$defs/NonEmptyString" },
                "errorType": { "$ref": "#/$defs/NullableNonEmptyString" },
                "errorDetail": { "$ref": "#/$defs/NullableNonEmptyString" },
                "logRef": { "$ref": "#/$defs/NullableNonEmptyString" },
                "context": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      ]
    }
  }
}
