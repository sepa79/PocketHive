{
  "name": "@pockethive/mcp-server",
  "version": "0.15.15",
  "description": "PocketHive MCP server — full lifecycle tools for scenario authoring and swarm management",
  "type": "module",
  "bin": {
    "pockethive-mcp": "./server.mjs"
  },
  "main": "./server.mjs",
  "files": [
