{
  "info": {
    "name": "PocketHive — Jira Bulk Issue Create",
    "_postman_id": "ph-jira-bulk-create-v1",
    "description": "Creates Jira issues from a CSV file using Postman's Collection Runner.\n\n## Setup\n1. Set the four collection variables below.\n2. In the Collection Runner, select this collection and upload pockethive_roadmap_jira_import.csv as the data file.\n3. Run — one issue is created per CSV row.\n\n## CSV columns\n- Summary      — issue title\n- Description  — issue body\n- Priority     — High / Medium / Low\n- Labels       — comma-separated, e.g. PocketHive\n- WorkType     — Story / Bug / Task / Epic",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "jira_base_url",
      "value": "https://your-org.atlassian.net",
      "description": "Jira Cloud base URL"
    },
    {
      "key": "jira_email",
      "value": "your-email@example.com",
      "description": "Jira account email for Basic Auth"
    },
    {
      "key": "jira_api_token",
      "value": "<your-jira-api-token>",
      "description": "API token from https://id.atlassian.com/manage-profile/security/api-tokens"
    },
    {
      "key": "jira_project_key",
      "value": "PH",
      "description": "Jira project key, e.g. PH"
    }
  ],
  "item": [
    {
      "name": "Create Issue from CSV Row",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const typeMap = { Story:'Story', Bug:'Bug', Task:'Task', Epic:'Epic', Subtask:'Sub-task' };",
              "const rawType = pm.iterationData.get('WorkType') || 'Story';",
              "const issueType = typeMap[rawType] || rawType;",
              "",
              "const rawLabels = pm.iterationData.get('Labels') || '';",
              "const labels = rawLabels.split(',').map(l => l.trim()).filter(Boolean);",
              "",
              "const priority = pm.iterationData.get('Priority') || 'Medium';",
              "const summary = pm.iterationData.get('Summary') || '';",
              "",
              "// Build ADF content — one paragraph per non-empty line",
              "const rawDesc = pm.iterationData.get('Description') || '';",
              "const lines = rawDesc.split(/\\n+/).map(l => l.trim()).filter(Boolean);",
              "if (lines.length === 0) lines.push(' ');",
              "const content = lines.map(line => ({",
              "  type: 'paragraph',",
              "  content: [{ type: 'text', text: line }]",
              "}));",
              "",
              "const body = {",
              "  fields: {",
              "    project:     { key: pm.collectionVariables.get('jira_project_key') },",
              "    summary:     summary,",
              "    issuetype:   { name: issueType },",
              "    priority:    { name: priority },",
              "    labels:      labels,",
              "    description: { type: 'doc', version: 1, content: content }",
              "  }",
              "};",
              "",
              "pm.variables.set('requestBody', JSON.stringify(body));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Issue created (201)', function () {",
              "  pm.expect(pm.response.code).to.equal(201);",
              "});",
              "if (pm.response.code === 201) {",
              "  const key = pm.response.json().key;",
              "  console.log('Created: ' + key + ' — ' + pm.iterationData.get('Summary'));",
              "} else {",
              "  console.error('FAILED: ' + pm.iterationData.get('Summary') + ' — ' + pm.response.text());",
              "}"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "basic",
          "basic": [
            { "key": "username", "value": "{{jira_email}}", "type": "string" },
            { "key": "password", "value": "{{jira_api_token}}", "type": "string" }
          ]
        },
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Accept", "value": "application/json" }
        ],
        "url": {
          "raw": "{{jira_base_url}}/rest/api/3/issue",
          "host": ["{{jira_base_url}}"],
          "path": ["rest", "api", "3", "issue"]
        },
        "body": {
          "mode": "raw",
          "raw": "{{requestBody}}"
        }
      }
    }
  ]
}
