{
  "name": "pockethive",
  "version": "0.15.28",
  "private": true,
  "description": "Development tooling for PocketHive",
  "scripts": {
    "build": "echo \"no build step\"",
    "lint": "eslint -c ui/eslint.config.js \"ui/src/**/*.{ts,tsx}\"",
    "mcp:agentic-evals": "npm run acceptance:agentic --prefix tools/pockethive-mcp",
    "mcp:doctor": "npm --prefix tools/pockethive-mcp run doctor --",
    "mcp:setup": "npm ci --prefix tools/pockethive-mcp",
    "mcp:start": "node tools/pockethive-mcp/start.cjs",
    "mcp:start:http": "npm --prefix tools/pockethive-mcp run start:http",
    "mcp:test": "npm test --prefix tools/pockethive-mcp",
    "mcp:workflow-acceptance": "npm run acceptance:workflow --prefix tools/pockethive-mcp",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "amqplib": "^0.10.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@stomp/stompjs": "^7.0.0",
    "@testing-library/jest-dom": "^6.5.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.4.3",
    "@xyflow/react": "^12.3.3",
    "eslint": "^9.34.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.7",
    "globals": "^15.14.0",
    "jsdom": "^26.1.0",
    "lucide-react": "^0.460.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript-eslint": "^8.16.0",
    "vitest": "^4.1.8",
    "zustand": "^4.5.2"
  },
  "license": "GPL-3.0-or-later"
}
