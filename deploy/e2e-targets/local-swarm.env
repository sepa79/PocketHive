# Local or HiveForge-reduced Swarm exposed on the current machine.
ORCHESTRATOR_BASE_URL=http://127.0.0.1:8088/orchestrator
SCENARIO_MANAGER_BASE_URL=http://127.0.0.1:8088/scenario-manager
NETWORK_PROXY_MANAGER_BASE_URL=http://127.0.0.1:8088/network-proxy-manager
AUTH_SERVICE_BASE_URL=http://127.0.0.1:8088/auth-service

UI_BASE_URL=http://127.0.0.1:8088
UI_WEBSOCKET_URI=ws://127.0.0.1:8088/ws

RABBITMQ_HOST=127.0.0.1
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_BASE_URL=http://127.0.0.1:15672/rabbitmq/api

POCKETHIVE_CONTROL_PLANE_EXCHANGE=ph.control
POCKETHIVE_CONTROL_PLANE_CONTROL_QUEUE_PREFIX=ph.control

POCKETHIVE_TCP_MOCK_URL=http://127.0.0.1:8083
POCKETHIVE_TCP_MOCK_USERNAME=admin
POCKETHIVE_TCP_MOCK_PASSWORD=admin

POCKETHIVE_REDIS_HOST=127.0.0.1
POCKETHIVE_REDIS_PORT=6379

POCKETHIVE_CLICKHOUSE_HTTP_URL=http://127.0.0.1:8123
POCKETHIVE_CLICKHOUSE_USERNAME=pockethive
POCKETHIVE_CLICKHOUSE_PASSWORD=pockethive

POCKETHIVE_AUTH_USERNAME=local-admin
SWARM_ID=pockethive-e2e-local-swarm
IDEMPOTENCY_KEY_PREFIX=ph-e2e-local-swarm
