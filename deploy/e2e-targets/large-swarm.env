# Large Proxmox Docker Swarm exposed from docker-swarm-mgr-1.
# Direct test-service ports use the current swarm-reduced host placement.
# Re-check these hosts after a stack redeploy until placement is pinned.
ORCHESTRATOR_BASE_URL=http://192.168.88.50:8088/orchestrator
SCENARIO_MANAGER_BASE_URL=http://192.168.88.50:8088/scenario-manager
NETWORK_PROXY_MANAGER_BASE_URL=http://192.168.88.50:8088/network-proxy-manager
AUTH_SERVICE_BASE_URL=http://192.168.88.50:8088/auth-service

UI_BASE_URL=http://192.168.88.50:8088
UI_WEBSOCKET_URI=ws://192.168.88.50:8088/ws

RABBITMQ_HOST=192.168.88.51
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_VHOST=/
RABBITMQ_MANAGEMENT_BASE_URL=http://192.168.88.51:15672/rabbitmq/api

POCKETHIVE_CONTROL_PLANE_EXCHANGE=ph.control
POCKETHIVE_CONTROL_PLANE_CONTROL_QUEUE_PREFIX=ph.control

POCKETHIVE_TCP_MOCK_URL=http://192.168.88.50:8083
POCKETHIVE_TCP_MOCK_USERNAME=admin
POCKETHIVE_TCP_MOCK_PASSWORD=admin

POCKETHIVE_REDIS_HOST=192.168.88.50
POCKETHIVE_REDIS_PORT=6379

POCKETHIVE_CLICKHOUSE_HTTP_URL=http://192.168.88.52:8123
POCKETHIVE_CLICKHOUSE_USERNAME=pockethive
POCKETHIVE_CLICKHOUSE_PASSWORD=pockethive

POCKETHIVE_AUTH_USERNAME=local-admin
SWARM_ID=pockethive-e2e-large-swarm
IDEMPOTENCY_KEY_PREFIX=ph-e2e-large-swarm
