# Copy to the remote deployment directory as .env and keep values explicit.

DOCKER_REGISTRY=registry.example.lan:5000/pockethive/
POCKETHIVE_CONTROL_PLANE_ORCHESTRATOR_IMAGE_REPOSITORY_PREFIX=registry.example.lan:5000/pockethive
POCKETHIVE_VERSION=dev-build-tag
POCKETHIVE_SCENARIOS_RUNTIME_ROOT=/opt/pockethive/scenarios-runtime

POCKETHIVE_AUTH_SERVICE_PROVIDER=DEV
POCKETHIVE_AUTH_SERVICE_SESSION_TTL=PT8H
POCKETHIVE_AUTH_SERVICE_ACCOUNT_ORCHESTRATOR_SECRET=orchestrator-local-secret
POCKETHIVE_AUTH_SERVICE_ACCOUNT_NETWORK_PROXY_MANAGER_SECRET=network-proxy-manager-local-secret
POCKETHIVE_AUTH_SERVICE_PRINCIPAL_NAME=orchestrator-service
POCKETHIVE_AUTH_SERVICE_PRINCIPAL_SECRET=orchestrator-local-secret
