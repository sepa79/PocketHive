# Example configuration for Proxmox/Docker remote helper scripts.
# Copy to deploy/proxmox.local.env for personal values. That file is ignored.

# Shared SSH settings
# Optional: export this in your shell to avoid passing --config every time.
# POCKETHIVE_PROXMOX_CONFIG=/home/<user>/.config/pockethive/proxmox.env
POCKETHIVE_SSH_KEY=/path/to/ssh/private-key
POCKETHIVE_REMOTE_USER=root

# Proxmox inventory helper
POCKETHIVE_PROXMOX_HOST=proxmox.example.lan
POCKETHIVE_PROXMOX_USER=root
POCKETHIVE_PROXMOX_VMIDS="240 241 242 243"

# Reduced single-node runtime helper
POCKETHIVE_REDUCED_REMOTE_HOST=pockethive-single.example.lan
POCKETHIVE_REDUCED_REMOTE_DIR=/opt/pockethive/runtime

# Swarm stack image inputs
DOCKER_REGISTRY=registry.example.lan:5000/pockethive/
POCKETHIVE_CONTROL_PLANE_ORCHESTRATOR_IMAGE_REPOSITORY_PREFIX=registry.example.lan:5000/pockethive
POCKETHIVE_VERSION=dev-build-tag

# Swarm node preparation helper
POCKETHIVE_SWARM_TRANSPORT=proxmox
POCKETHIVE_SWARM_NODE_HOST=swarm-manager.example.lan
POCKETHIVE_SWARM_NODE_VMID=240
POCKETHIVE_SWARM_ROOT=/opt/pockethive/swarm
POCKETHIVE_SCENARIOS_RUNTIME_ROOT=/mnt/shared/pockethive/scenarios-runtime
